{
  "version": 2,

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },

    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/dashboard.html"
    },

    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/login.html",
      "dest": "/login.html"
    },

    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
