{
  "version": 2,

  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "dashboard.html", "use": "@vercel/static" },
    { "src": "login.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "dashboard.js", "use": "@vercel/static" },
    { "src": "teams.js", "use": "@vercel/static" },
    { "src": "parlay.js", "use": "@vercel/static" },
    { "src": "token.js", "use": "@vercel/static" },
    { "src": "assets/(.*)", "use": "@vercel/static" },

    { "src": "api/events.js", "use": "@vercel/node" },
    { "src": "api/odds.js", "use": "@vercel/node" },
    { "src": "api/event-odds.js", "use": "@vercel/node" }
  ],

  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },

    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },

    { "src": "/login", "dest": "/login.html" },
    { "src": "/login.html", "dest": "/login.html" },

    { "src": "/(.*)", "dest": "/$1" }
  ]
}
