{
  "version": 2,

  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "teams.js", "use": "@vercel/static" },

    { "src": "api/events.js", "use": "@vercel/node" },
    { "src": "api/props.js", "use": "@vercel/node" }
  ],

  "routes": [
    {
      "src": "/api/events",
      "dest": "/api/events.js",
      "headers": { "Cache-Control": "no-store" }
    },
    {
      "src": "/api/props",
      "dest": "/api/props.js",
      "headers": { "Cache-Control": "no-store" }
    },

    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],

  "env": {
    "ODDS_API_KEY": "@odds_api_key"
  }
}